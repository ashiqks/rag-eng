        <mxCell id="title" value="D4 - Data Flow Diagram (OWASP-style)&#xa;External entities (rectangles), Processes (circles), Data stores (open rectangles), Trust boundaries (red dashed)" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#202124;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="1660" height="40" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="Notation&#xa;Rectangle = External Entity   |   Circle = Process   |   Open rectangle (=) = Data store   |   Red dashed = Trust boundary&#xa;Edge label = data class + protocol + auth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5F6368;dashed=1;fontSize=10;fontColor=#202124;align=left;spacingLeft=10;" vertex="1" parent="1">
