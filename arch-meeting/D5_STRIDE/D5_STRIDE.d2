# D5 - STRIDE Threat Model on DFD
# Render: d2 --layout=elk --theme=1 D5_STRIDE.d2 D5_STRIDE.svg

direction: right

title: "D5 - STRIDE Threat Model | gap-genai-discovery | 12 H/M threats on the DFD" {
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

legend: "STRIDE legend\nS=Spoofing  T=Tampering  R=Repudiation\nI=Info disclosure  D=Denial of service  E=Elevation of privilege\nSeverity: red=H  orange=M  grey=OPEN" {
  shape: text
  style.font-size: 14
  style.bold: true
}

# ============ TB1 INTERNET ============
tb1: "TB1 Internet" {
  style.fill: "#FFEBEE"; style.stroke: "#C62828"; style.stroke-dash: 5
  e1: "E1 User" {shape: person}
  e2: "E2 Workspace IdP" {shape: cloud}
}

# ============ TB2 IAP ============
tb2: "TB2 Edge / IAP" {
  style.fill: "#FFF3E0"; style.stroke: "#E65100"; style.stroke-dash: 5
  p0: "P0 IAP" {shape: oval; style.fill: "#1976D2"; style.font-color: "#FFFFFF"}
}

# ============ TB3 INTERNAL MESH ============
tb3: "TB3 Cloud Run mesh" {
  style.fill: "#E8F5E9"; style.stroke: "#137333"; style.stroke-dash: 5

  p1: "P1 web (sa-web)" {shape: oval; style.fill: "#4284F3"; style.font-color: "#FFFFFF"}
  p2: "P2 gateway (sa-gateway)" {shape: oval; style.fill: "#4284F3"; style.font-color: "#FFFFFF"}
  p3: "P3 agent (sa-agent)" {shape: oval; style.fill: "#4284F3"; style.font-color: "#FFFFFF"}
  p5: "P5 exporter (sa-exporter)" {shape: oval; style.fill: "#34A853"; style.font-color: "#FFFFFF"}
  p6: "P6 reindex (sa-reindex)" {shape: oval; style.fill: "#34A853"; style.font-color: "#FFFFFF"}
  p9: "P9 Cloud Build" {shape: oval; style.fill: "#5F6368"; style.font-color: "#FFFFFF"}

  ds6: "DS6 Secret Manager" {shape: cylinder; style.fill: "#C62828"; style.font-color: "#FFFFFF"}
  ds7: "DS7 KMS" {shape: cylinder; style.fill: "#C62828"; style.font-color: "#FFFFFF"}
  ds8: "DS8 Artifact Registry" {shape: cylinder; style.fill: "#5F6368"; style.font-color: "#FFFFFF"}
  ds9: "DS9 Cloud Observability Suite\n(Logging + Monitoring + Trace, AR-5)" {shape: cylinder; style.fill: "#1A73E8"; style.font-color: "#FFFFFF"}
}

# ============ TB4 VPC-SC ============
tb4: "TB4 VPC-SC perimeter" {
  style.fill: "#F3E8FD"; style.stroke: "#8430CE"; style.stroke-dash: 5
  ds1: "DS1 VAIS engine + sessions" {shape: cylinder; style.fill: "#8430CE"; style.font-color: "#FFFFFF"}
  ds2: "DS2 Model Garden" {shape: cylinder; style.fill: "#8430CE"; style.font-color: "#FFFFFF"}
  p4: "P4 Managed BQ MCP\nbigquery.googleapis.com/mcp" {shape: oval; style.fill: "#1ABC9C"; style.font-color: "#FFFFFF"}
  ds3: "DS3 GCS corpus-html" {shape: cylinder; style.fill: "#F9A825"; style.font-color: "#FFFFFF"}
  ds4: "DS4 BQ ops dataset" {shape: cylinder; style.fill: "#F9A825"; style.font-color: "#FFFFFF"}
  ds5: "DS5 BQ v_experiment_kpis (authorized view)" {shape: cylinder; style.fill: "#F9A825"; style.font-color: "#FFFFFF"}
}

# ============ TB5 SaaS ============
tb5: "TB5 External SaaS" {
  style.fill: "#E1F5FE"; style.stroke: "#0277BD"; style.stroke-dash: 5
  e3: "E3 Confluence Cloud" {shape: cloud; style.fill: "#0052CC"; style.font-color: "#FFFFFF"}
  e4: "E4 GitHub" {shape: cloud}
}

# ============ CORE DFD FLOWS (minimal so the threats are readable) ============
tb1.e1 -> tb2.p0: "F3 query" {style.stroke: "#1A73E8"}
tb1.e2 -> tb2.p0: "F2 ID token" {style.stroke: "#1A73E8"; style.stroke-dash: 3}
tb2.p0 -> tb3.p1: "F4" {style.stroke: "#1A73E8"}
tb3.p1 -> tb3.p2: "F5" {style.stroke: "#1A73E8"}
tb3.p2 -> tb3.p3: "F6" {style.stroke: "#1A73E8"}
tb3.p3 -> tb4.ds1: "F7 :answer" {style.stroke: "#8430CE"}
tb4.ds1 -> tb4.ds2: "F8 gen" {style.stroke: "#8430CE"; style.stroke-dash: 3}
tb3.p3 -> tb4.p4: "F9 MCP tool call (sa-agent)" {style.stroke: "#1ABC9C"}
tb4.p4 -> tb4.ds5: "F10a jobs.query (sa-agent on view)" {style.stroke: "#F9A825"}
tb3.p3 -> tb4.ds4: "F10b feedback INSERT (sa-agent)" {style.stroke: "#F9A825"; style.stroke-dash: 3}
tb3.p5 -> tb5.e3: "F12 NAT" {style.stroke: "#E65100"}
tb3.p5 -> tb4.ds3: "F13" {style.stroke: "#F9A825"}
tb3.p6 -> tb4.ds3: "F14" {style.stroke: "#F9A825"; style.stroke-dash: 3}
tb3.p6 -> tb4.ds1: "F15" {style.stroke: "#8430CE"}
tb3.p5 -> tb3.ds6: "F18 PAT" {style.stroke: "#C62828"; style.stroke-dash: 3}
tb3.ds7 -> tb4.ds3: "F19 CMEK" {style.stroke: "#C62828"; style.stroke-dash: 3}
tb3.ds7 -> tb4.ds4: "F19 CMEK" {style.stroke: "#C62828"; style.stroke-dash: 3}
tb5.e4 -> tb3.p9: "F20" {style.stroke: "#5F6368"; style.stroke-dash: 3}
tb3.p9 -> tb3.ds8: "F21" {style.stroke: "#5F6368"; style.stroke-dash: 3}

# ============ THREAT MARKERS ============
threats: "STRIDE threats (H = red, M = orange, OPEN = grey)" {
  style.fill: "#FFFFFF"
  style.stroke: "#C62828"
  style.stroke-dash: 5
  style.stroke-width: 2

  t1: "T1 (S) JWT forge / IAP bypass\nH - tighten IAP audience, enforce hd=gap.com" {shape: callout; style.fill: "#FFEBEE"; style.stroke: "#C62828"}
  t2: "T2 (T) Prompt injection in retrieved doc\nH - system-prompt isolation + output filter" {shape: callout; style.fill: "#FFEBEE"; style.stroke: "#C62828"}
  t3: "T3 (I) PII in queries logged to BQ\nH - redact pre-log, BQ column-level ACL" {shape: callout; style.fill: "#FFEBEE"; style.stroke: "#C62828"}
  t4: "T4 (E) sa-agent over-permissioned\nH - drop to discoveryengine.viewer + aiplatform.user" {shape: callout; style.fill: "#FFEBEE"; style.stroke: "#C62828"}
  t5: "T5 (I) Cross-session leakage in VAIS sessions\nH - scope userPseudoId, server-side filter" {shape: callout; style.fill: "#FFEBEE"; style.stroke: "#C62828"}
  t6: "T6 (T) Index poisoning via Confluence edit\nM - sidecar review + diff alert on reindex" {shape: callout; style.fill: "#FFF3E0"; style.stroke: "#E65100"}
  t7: "T7 (E) PAT used by wrong SA\nM - secret IAM = sa-exporter only" {shape: callout; style.fill: "#FFF3E0"; style.stroke: "#E65100"}
  t8: "T8 (OPEN) Vault vs Secret Manager\nOPEN Q14 - PSEC to decide" {shape: callout; style.fill: "#ECEFF1"; style.stroke: "#5F6368"}
  t9: "T9 (T) Malicious npm/pypi dep in build\nM - Artifact Analysis + SBOM + Binauthz" {shape: callout; style.fill: "#FFF3E0"; style.stroke: "#E65100"}
  t10: "T10 (R) Audit log tampering\nM - sink to BQ with retention lock + CMEK" {shape: callout; style.fill: "#FFF3E0"; style.stroke: "#E65100"}
  t11: "T11 (E) Unconstrained execute_sql via managed MCP\nM - IAM deny policy on roles/mcp.toolWriteUser;\nsa-agent dataViewer ONLY on view v_experiment_kpis\n(raw tables hidden); Model Armor inspects payloads" {shape: callout; style.fill: "#FFF3E0"; style.stroke: "#E65100"}
  t12: "T12 (OPEN) Public LB acceptable?\nOPEN Q24 - PSEC to decide internal-only" {shape: callout; style.fill: "#ECEFF1"; style.stroke: "#5F6368"}
  t13: "T13 (D) LLM token-cost spike via prompt loops / runaway agent\nM - Cloud Billing budget alert + Monitoring alert on llm_tokens_out rate\n+ Cloud Run max-instances cap (AR-6)" {shape: callout; style.fill: "#FFF3E0"; style.stroke: "#E65100"}
}

# ============ THREAT -> ASSET EDGES (dashed red) ============
threats.t1 -> tb2.p0 {style.stroke: "#C62828"; style.stroke-dash: 3}
threats.t2 -> tb3.p3 {style.stroke: "#C62828"; style.stroke-dash: 3}
threats.t2 -> tb4.ds2 {style.stroke: "#C62828"; style.stroke-dash: 3}
threats.t3 -> tb4.ds4 {style.stroke: "#C62828"; style.stroke-dash: 3}
threats.t4 -> tb3.p3 {style.stroke: "#C62828"; style.stroke-dash: 3}
threats.t5 -> tb4.ds1 {style.stroke: "#C62828"; style.stroke-dash: 3}
threats.t6 -> tb4.ds3 {style.stroke: "#E65100"; style.stroke-dash: 3}
threats.t6 -> tb4.ds1 {style.stroke: "#E65100"; style.stroke-dash: 3}
threats.t7 -> tb3.ds6 {style.stroke: "#E65100"; style.stroke-dash: 3}
threats.t8 -> tb3.ds6 {style.stroke: "#5F6368"; style.stroke-dash: 3}
threats.t9 -> tb3.ds8 {style.stroke: "#E65100"; style.stroke-dash: 3}
threats.t9 -> tb3.p9 {style.stroke: "#E65100"; style.stroke-dash: 3}
threats.t10 -> tb3.ds9 {style.stroke: "#E65100"; style.stroke-dash: 3}
threats.t11 -> tb4.p4 {style.stroke: "#E65100"; style.stroke-dash: 3}
threats.t12 -> tb2.p0 {style.stroke: "#5F6368"; style.stroke-dash: 3}
threats.t13 -> tb4.ds2 {style.stroke: "#E65100"; style.stroke-dash: 3}
threats.t13 -> tb4.ds1 {style.stroke: "#E65100"; style.stroke-dash: 3}
