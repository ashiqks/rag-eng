# GCP & Vertex AI Eval Service
GCP_PROJECT_ID=prj-0n-dta-pt-ai-sandbox
GCP_REGION=us-central1

# Vertex AI Search engine (the app under test)
SEARCH_PROJECT_ID=prj-0n-dta-pt-ai-sandbox
SEARCH_LOCATION=global
SEARCH_COLLECTION=default_collection
SEARCH_ENGINE_ID=gap-erd-discovery_1779708094567
SEARCH_SERVING_CONFIG=default_search

# Eval config
JUDGE_MODEL=gemini-3.1-pro-preview
EVAL_CONCURRENCY=8

# Named search/answer configuration to apply (see configs.py).
# 'preview+prompt' is the sweep winner on the user 15-question set
# (highest answer_correctness, highest context_recall).
# Other options: baseline (default request body, for delta comparisons),
# prompt-only, flash-2.5+prompt, preview+recall, preview+grounding,
# kitchen-sink.
EVAL_CONFIG=preview+prompt

# I/O (optional - paths resolved relative to tests/eval/ if not absolute)
EVAL_QUESTIONS_CSV=eval_questions.csv
EVAL_RUNS_DIR=runs

# Outbound HTTPS proxy (optional). Set only if your network requires it for
# *.googleapis.com egress. Format: http://host:port (or with creds).
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=localhost,127.0.0.1,.local
